# Ansible Managed

[Unit]
Description=Voctomix startup commands

# Wants=videoteam-voctocore.service
Requires=videoteam-voctocore.service
PartOf=videoteam-voctocore.service
After=network.target

# After=videoteam-voctocore.service

# BindsTo=videoteam-voctocore.service

# ReloadPropagatedFrom=videoteam-voctocore.service
# StopPropagatedFrom=videoteam-voctocore.service

# OnSuccess=videoteam-voctocore.service

# Upholds=videoteam-voctocore.service
# Requisite=videoteam-voctocore.service
# RequisiteOf=videoteam-voctocore.service

[Service]
Type=oneshot
RemainAfterExit=yes

User={{ user_name }}
Group={{ user_name }}

ExecStart=/home/videoteam/voctomix-outcasts/voctocore-cmds.py --delay 2.5 -f /etc/voctomix/vocto.cmds --wait-for-core
Nice=10

[Install]
# WantedBy=default.target
WantedBy=multi-user.target
# UpheldBy=videoteam-voctocore.service

